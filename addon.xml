<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.service.ghome"
       name="G HOME Startup Service"
       version="1.0.0"
       provider-name="Ganpatii Enterprise">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.service" library="service.py" start="startup"/>

    <extension point="xbmc.addon.metadata">
        <summary>G HOME Startup Service</summary>
        <description>
            Auto startup service for G HOME.
            Checks internet,
            reads GitHub config,
            plays startup videos,
            opens Favorites automatically.
        </description>

        <platform>all</platform>

        <license>Private</license>

        <source>
            https://github.com/YOUR_USERNAME/ghome-startup
        </source>

    </extension>

</addon>
