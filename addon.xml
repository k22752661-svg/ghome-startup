<?xml version="1.0" encoding="UTF-8"?>
<addon id="service.gmovies.startup"
       name="G-Movies Startup"
       version="1.0.0"
       provider-name="G-Movies">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.service" library="service.py" start="startup"/>

    <extension point="xbmc.addon.metadata">
        <summary>G-Movies Startup Service</summary>
        <description>
            Startup Manager, Welcome Video, Advertisement,
            Plan Check, Offline Mode, Auto Redirect,
            Background Scheduler
        </description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>

</addon>
